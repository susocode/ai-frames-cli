{
  "name": "@ai-frames/server",
  "version": "0.1.1",
  "description": "ai-frames server — API + static UI server",
  "main": "dist/index.js",
  "bin": {
    "ai-frames": "../../bin/ai-frames.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:debug": "AIFRAME_DEBUG=1 tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint src",
    "build:binary:mac-arm": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile ../../bin/ai-frames-macos-arm64",
    "build:binary:mac-x64": "bun build ./src/index.ts --compile --target=bun-darwin-x64  --outfile ../../bin/ai-frames-macos-x64",
    "build:binary:linux":   "bun build ./src/index.ts --compile --target=bun-linux-x64    --outfile ../../bin/ai-frames-linux-x64"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "devcert": "^1.2.3",
    "express": "^4.19.2",
    "keytar": "^7.9.0",
    "open": "^10.1.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
